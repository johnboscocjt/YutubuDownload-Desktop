mark_low_network_progress() {
    local immediate="${1:-false}"
    if [[ "$immediate" == "true" ]]; then
        LOW_NETWORK_PROGRESS=true
        LOW_NETWORK_WEAK_STREAK=3
        LOW_NETWORK_STABLE_STREAK=0
