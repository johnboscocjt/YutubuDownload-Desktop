# Keep yt-dlp current — YouTube breaks older builds frequently (audio/JS challenges).
ensure_ytdlp_ready() {
    local user_bin="${HOME}/.local/bin"
    mkdir -p "$user_bin"

    if [[ -x "$user_bin/yt-dlp" ]]; then
        export PATH="$user_bin:$PATH"
    fi

    if ! command -v yt-dlp &> /dev/null; then
        echo -e "${SKY_BLUE}⬇️  Installing yt-dlp to ${user_bin}...${RESET}"
        if curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o "$user_bin/yt-dlp"; then
            chmod +x "$user_bin/yt-dlp"
            export PATH="$user_bin:$PATH"
        else
            return 1
        fi
    fi

    if yt-dlp -U >/dev/null 2>&1; then
        :
    elif [[ -w "$user_bin" ]]; then
        local age=999999
        if [[ -f "$user_bin/yt-dlp" ]]; then
            age=$(( $(date +%s) - $(stat -c %Y "$user_bin/yt-dlp" 2>/dev/null || echo 0) ))
        fi
        if [[ ! -x "$user_bin/yt-dlp" ]] || (( age > 86400 )); then
            echo -e "${SKY_BLUE}🔄 Refreshing yt-dlp (no sudo needed)...${RESET}"
            if curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o "$user_bin/yt-dlp.tmp"; then
                chmod +x "$user_bin/yt-dlp.tmp"
                mv -f "$user_bin/yt-dlp.tmp" "$user_bin/yt-dlp"
                export PATH="$user_bin:$PATH"
            fi
        fi
    fi

    command -v yt-dlp &> /dev/null
}

# === HELPER FUNCTION FOR PADDED COLORED OUTPUT ===
print_padded() {
    local label="$1"
    local colored_text="$2"
    local total_width=78
    local plain_text=$(echo -e "$colored_text" | sed -r "s/\x1B\[([0-9]{1,3}(;[0-9]{1,2})?)?[mGK]//g")
    local text_length=${#plain_text}
    local label_length=${#label}
    local total_length=$((label_length + text_length))
    local padding=$((total_width - total_length))
    printf "${BRIGHT_GREEN}║${RESET} ${CYAN}%s${RESET} %s%*s ${BRIGHT_GREEN}║${RESET}\n" "$label" "$colored_text" "$padding" ""
}

