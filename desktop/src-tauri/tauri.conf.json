{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YutubuDownload",
  "version": "2.0.1",
  "identifier": "com.johnboscocjt.yutubudownload",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YutubuDownload",
        "width": 960,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost tauri:; media-src 'self' asset: http://asset.localhost ytd-media: http://ytd-media.localhost blob: data:; img-src 'self' asset: http://asset.localhost https: data:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$DOWNLOAD/**",
            "$VIDEO/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$TEMP/**",
            "/tmp/**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
