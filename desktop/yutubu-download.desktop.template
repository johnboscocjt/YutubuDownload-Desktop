[Desktop Entry]
Name=YutubuDownload
Comment=Youtube downloader with in-app playback (wrapped with D-Bus session)
Exec=dbus-run-session -- /usr/local/bin/yutubu-download %U
Icon=yutubu-download
Type=Application
Categories=AudioVideo;Network;Utility;
StartupWMClass=YutubuDownload
Terminal=false

